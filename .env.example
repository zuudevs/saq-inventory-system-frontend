# Base URL API backend SAQ Inventory System.
# Saat development, biarkan kosong / gunakan "/api" agar lewat proxy Vite
# (lihat vite.config.ts) sehingga tidak perlu setting CORS di backend.
VITE_API_BASE_URL=/api

# Base URL untuk menampilkan file gambar yang di-serve backend lewat
# route "/storage/*" (lihat StorageRoutes di backend).
VITE_STORAGE_BASE_URL=/storage
